{
  "name": "bioagent",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered bioinformatics agent — 自然语言驱动的自动化单细胞及多组学数据分析",
  "scripts": {
    "dev": "pnpm --filter @bioagent/ui dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "test:e2e": "pnpm -r test:e2e",
    "clean": "pnpm -r clean",
    "seed:knowledge": "pnpm --filter @bioagent/knowledge seed"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
