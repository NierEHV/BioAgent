# === BioAgent Core ===
BIOAGENT_MODEL=claude-sonnet-4-6
BIOAGENT_MAX_TOKENS=4096
BIOAGENT_THINKING_BUDGET=high
BIOAGENT_TEMPERATURE=0.1

# === LLM Provider (pi-ai) ===
ANTHROPIC_API_KEY=sk-ant-...
PI_AI_DEFAULT_PROVIDER=anthropic

# === Paths ===
BIOAGENT_DATA_DIR=./data
BIOAGENT_PROJECTS_DIR=./data/projects
BIOAGENT_SESSIONS_DIR=./data/sessions
BIOAGENT_LOGS_DIR=./data/logs
BIOAGENT_KNOWLEDGE_DIR=./packages/knowledge/data

# === Docker ===
DOCKER_DEFAULT_PLATFORM=linux/amd64
DOCKER_PULL_TIMEOUT=3600000
DOCKER_EXEC_DEFAULT_TIMEOUT=600000

# === ChromaDB ===
CHROMA_URL=http://localhost:8000
CHROMA_PERSIST_DIR=./data/chroma

# === KuzuDB ===
KUZU_DB_PATH=./data/kuzu

# === Execution ===
REQUIRE_USER_CONFIRMATION=true
MAX_PARALLEL_SKILLS=4
MAX_SESSION_LENGTH=200
AUTO_COMPRESS_SESSION=true
SESSION_COMPRESS_THRESHOLD=150

# === Logging ===
LOG_LEVEL=info
LOG_FORMAT=json
